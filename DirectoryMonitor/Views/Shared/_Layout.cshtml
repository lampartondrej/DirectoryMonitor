<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Directory Monitor</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        html.dm-dark .dm-analyze-btn {
            filter: brightness(0.62) !important;
        }
        html.dm-dark .dm-analyze-btn:hover {
            filter: brightness(0.72) !important;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-md dm-navbar">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M1 3.5A1.5 1.5 0 0 1 2.5 2h2.764c.958 0 1.76.56 2.311 1.184C7.985 3.648 8.48 4 9 4h4.5A1.5 1.5 0 0 1 15 5.5v7a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 1 12.5v-9z"/>
                </svg>
                Directory Monitor
            </a>

            <button class="btn dm-theme-toggle ms-auto" id="themeToggle" title="Toggle dark / light mode" type="button" aria-label="Toggle colour scheme">
                <!-- Moon icon — shown in light mode -->
                <svg id="iconMoon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M6 .278a.77.77 0 0 1 .08.858 7.208 7.208 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277q.792-.001 1.533-.16a.787.787 0 0 1 .81.316.733.733 0 0 1-.031.893A8.349 8.349 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.752.752 0 0 1 6 .278z"/>
                </svg>
                <!-- Sun icon — shown in dark mode -->
                <svg id="iconSun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true" style="display:none">
                    <path d="M8 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0zm0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13zm8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5zM3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8zm10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0zm-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0zm9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707zM4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708z"/>
                </svg>
            </button>
        </div>
    </nav>

    <main class="container py-5">
        @RenderBody()
    </main>

    <footer class="dm-footer">
        <div class="container text-center">
            <small class="text-muted">Directory Monitor &mdash; Technical Interview Assignment</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
    // Dark-mode toggle. Uses class "dm-dark" on <html> — fully self-contained,
    // no dependency on Bootstrap 5.3+ data-bs-theme. Persists to localStorage
    // and respects the OS prefers-color-scheme on first visit.
    (function () {
        var html     = document.documentElement;
        var toggle   = document.getElementById('themeToggle');
        var iconMoon = document.getElementById('iconMoon');
        var iconSun  = document.getElementById('iconSun');

        function applyTheme(theme) {
            if (theme === 'dark') {
                html.classList.add('dm-dark');
                iconMoon.style.display = 'none';
                iconSun.style.display  = '';
            } else {
                html.classList.remove('dm-dark');
                iconMoon.style.display = '';
                iconSun.style.display  = 'none';
            }
        }

        var saved = localStorage.getItem('dm-theme') ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        applyTheme(saved);

        toggle.addEventListener('click', function () {
            var next = html.classList.contains('dm-dark') ? 'light' : 'dark';
            localStorage.setItem('dm-theme', next);
            applyTheme(next);
        });
    }());
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
